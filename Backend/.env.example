# Copy this file to `.env` and fill in your key.
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Optional: model choice.
# - claude-haiku-4-5-20251001  → fastest, cheapest (~$0.01-0.03 per conversation)
# - claude-sonnet-4-6          → richer reasoning (~$0.05-0.20 per conversation)
MODEL=claude-haiku-4-5-20251001

# Optional: server port. Default 8000.
PORT=8000
