# ─── Aria · live mode environment template ─────────────────────────────
# Copy this file to output/demo-app/backend/.env and paste your real key.
# Never commit a populated .env to git.

# Anthropic Claude · the supported provider out of the box
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Model · pick the right speed/quality trade-off
# Options: claude-haiku-4-5-20251001 · claude-sonnet-4-6 · claude-opus-4-7
MODEL=claude-haiku-4-5-20251001

# Server port · the URL becomes http://localhost:<PORT>/
PORT=8000

# ─── Future alternative providers (not wired today) ─────────────────────
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...
# Uncomment + extend backend/server.py + backend/agents.py if you want to
# swap to OpenAI or xAI Grok. Default install supports Anthropic only.
